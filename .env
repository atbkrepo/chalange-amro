# Database (auth service)
POSTGRES_DB=authdb
POSTGRES_USER=auth_user
POSTGRES_PASSWORD=changeme

# OAuth2 clients
SERVICE_CLIENT_ID=internal-service
SERVICE_CLIENT_SECRET=changeme
EXTERNAL_CLIENT_ID=external-app
EXTERNAL_CLIENT_SECRET=changeme

# Admin user
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Eureka (discovery service)
EUREKA_USER=eureka
EUREKA_PASSWORD=changeme

# SSL (config server)
SSL_KEY_STORE_PASSWORD=changeit

# Config server Git repo (SSH)
CONFIG_GIT_URI=git@github.com:atbkrepo/config-server.git
CONFIG_GIT_LABEL=main
