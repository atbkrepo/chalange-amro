# Copy to .env and fill in values. Do not commit .env.

# Database (auth service)
AUTH_POSTGRES_DB=authdb
AUTH_POSTGRES_USER=auth_user
AUTH_POSTGRES_PASSWORD=

# Database (orders service)
ORDERS_POSTGRES_DB=ordersdb
ORDERS_POSTGRES_USER=orders_user
ORDERS_POSTGRES_PASSWORD=

# OAuth2 clients (auth)
SERVICE_CLIENT_ID=
SERVICE_CLIENT_SECRET=
EXTERNAL_CLIENT_ID=
EXTERNAL_CLIENT_SECRET=

# Admin user (auth)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Eureka
EUREKA_USER=eureka
EUREKA_PASSWORD=

# TLS stores (shared by config/auth/orders in compose)
SSL_KEY_STORE_PASSWORD=
SSL_KEY_STORE_PATH=file:/app/ssl/keystore.p12
COMMON_TLS_TRUST_STORE_PATH=file:/app/ssl/truststore.p12
SSL_DISCOVERY_KEY_ALIAS=discovery
SSL_CONFIG_KEY_ALIAS=config-server
SSL_AUTH_KEY_ALIAS=auth
SSL_ORDERS_KEY_ALIAS=orders

# Email (orders) — optional
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
NOTIFICATION_ENABLED=false
NOTIFICATION_FROM_EMAIL=noreply@example.com

# Config server Git
CONFIG_GIT_URI=
CONFIG_GIT_LABEL=main
